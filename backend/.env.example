# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/kids_app
MONGO_MAX_POOL=10
MONGO_MIN_POOL=2

# JWT Secrets (Change these in production!)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Client URL (Frontend)
CLIENT_URL=http://localhost:5173

# HTTPS return page after Chapa checkout (custom schemes like myapp:// break Chapa)
FRONTEND_URL=https://yeneta-zq3w.onrender.com/api/v1/payments/chapa/return?status=success
CHAPA_RETURN_URL=https://yeneta-zq3w.onrender.com/api/v1/payments/chapa/return?status=success

# Token Expiration
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=7d

# Chapa Payment Gateway
# Get your keys from: https://dashboard.chapa.co/
# Webhook URL to configure in Chapa dashboard: https://your-domain.com/api/v1/payments/chapa/webhook
CHAPA_SECRET_KEY=CHASECK_TEST-VewQ4oyFKOqVd1rxnmWZ5s3DPEpwNZbe
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-vvG0xm6nFCJ5ukgtE1Vfc7da6U2mIej0
CHAPA_ENCRYPTION_KEY=vc4RxxPWvrQR0QoRQ6chNKln
CHAPA_WEBHOOK_SECRET=your_webhook_secret_here
CHAPA_CALLBACK_URL=https://yeneta-zq3w.onrender.com/api/v1/payments/chapa/webhook

# Cloudinary (admin content uploads — thumbnails, covers, videos, audio)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=yeneta
